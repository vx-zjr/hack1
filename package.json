{
  "name": "hackos-electron-demo",
  "version": "1.0.0",
  "description": "Pure frontend HACK//OS red-team UI demo built with Electron, Vite, React, Three.js, and Tailwind CSS.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,TSC,ELECTRON -c green,cyan,magenta \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist-electron/main.js && node scripts/start-electron.mjs\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json --noEmit",
    "visual:smoke": "node scripts/visual-smoke.mjs"
  },
  "build": {
    "appId": "local.hackos.demo",
    "productName": "HACK OS Demo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  }
}
